#!/usr/bin/env bash
# UserPromptSubmit hook: detect four-file disk memory and remind Claude to read.
# Supports dual-track filenames (Chinese canonical + English aliases).
# Hooks fail open — any error → exit 0, never block the protocol.

set +e

# Dual-track filename pairs (canonical / alias)
declare -a files=(
  "项目规划清单.md"   "plan.md"
  "编辑清单.md"       "edits.md"
  "硬件资源表.md"     "hw-resources.md"
  "研究发现.md"       "findings.md"
)

found_any=0
for f in "${files[@]}"; do
  if [ -f "$f" ]; then
    echo "[embedded-dev] 检测到 $f，请确保已读取最新内容。"
    found_any=1
  fi
done

# Silent when no files exist (clean project, no protocol state yet)
exit 0
