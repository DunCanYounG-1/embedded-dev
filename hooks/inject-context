#!/usr/bin/env bash
# PreToolUse (Write|Edit|Bash) hook: inject relevant memory file snippets
# so Claude has fresh context before each tool call.
# Dual-track filename support; hooks fail open.

set +e

# Plan / 项目规划清单
for f in 项目规划清单.md plan.md; do
  if [ -f "$f" ]; then
    echo "[embedded-dev] $f（前 20 行）:"
    head -20 "$f" 2>/dev/null
    break
  fi
done

# Hardware resources / 硬件资源表 — chip & toolchain section
for f in 硬件资源表.md hw-resources.md; do
  if [ -f "$f" ]; then
    echo "[embedded-dev] $f（芯片与开发环境段）:"
    sed -n '/## 芯片与开发环境\|## Chip & Toolchain/,/## 引脚分配表\|## Pin Assignments/p' "$f" 2>/dev/null | head -15
    break
  fi
done

# Findings / 研究发现 — recent technical findings
for f in 研究发现.md findings.md; do
  if [ -f "$f" ]; then
    echo "[embedded-dev] $f（最近发现）:"
    sed -n '/## 技术发现\|## Findings/,/^## /p' "$f" 2>/dev/null | head -20
    break
  fi
done

exit 0
