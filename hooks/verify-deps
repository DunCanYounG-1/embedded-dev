#!/usr/bin/env bash
# Verify embedded-dev dependencies. Reports tri-state status (✓/⚠/✗) for each
# component, never blocks. Designed to be the first command a new user runs
# after cloning, to know what's working and what needs to be installed.
#
# Usage: bash ~/.claude/skills/embedded-dev/hooks/verify-deps

set +e

OK="\033[32m✓\033[0m"
WARN="\033[33m⚠\033[0m"
ERR="\033[31m✗\033[0m"

# Disable colors if stdout is not a tty (cleaner for CI / pipe redirect)
if [ ! -t 1 ]; then
  OK="[OK]"
  WARN="[WARN]"
  ERR="[MISSING]"
fi

print_header() {
  echo ""
  echo "=========================================="
  echo "  $1"
  echo "=========================================="
}

check_cmd() {
  local name="$1"
  local cmd="$2"
  local verify_arg="${3:---version}"
  local probe
  probe="$(command -v "$cmd" 2>/dev/null)"
  if [ -z "$probe" ]; then
    printf "  %b %s — not found\n" "$ERR" "$name"
    return 1
  fi
  # Some Windows stubs (python3 from Microsoft Store) exit 0 with empty output.
  # Require non-empty output to count as real.
  local out
  out="$("$cmd" "$verify_arg" 2>&1 | head -1)"
  if [ -z "$out" ]; then
    printf "  %b %s — stub detected (no real %s)\n" "$WARN" "$name" "$cmd"
    return 1
  fi
  printf "  %b %s — %s\n" "$OK" "$name" "$out"
  return 0
}

check_path() {
  local label="$1"
  local path="$2"
  if [ -e "$path" ]; then
    printf "  %b %s — %s\n" "$OK" "$label" "$path"
    return 0
  else
    printf "  %b %s — %s (缺失)\n" "$WARN" "$label" "$path"
    return 1
  fi
}

check_skill() {
  local skill="$1"
  local desc="$2"
  if [ -d "$HOME/.claude/skills/$skill" ] || [ -d "$HOME/.claude/plugins/$skill" ]; then
    printf "  %b /%-30s — %s\n" "$OK" "$skill" "$desc"
    return 0
  fi
  printf "  %b /%-30s — %s\n" "$WARN" "$skill" "$desc"
  return 1
}

check_url() {
  local label="$1"
  local url="$2"
  if command -v curl >/dev/null 2>&1; then
    local code
    code="$(curl -s -o /dev/null -w '%{http_code}' -m 5 "$url" 2>/dev/null)"
    if [ "$code" = "200" ] || [ "$code" = "401" ] || [ "$code" = "403" ]; then
      printf "  %b %s — HTTP %s\n" "$OK" "$label" "$code"
      return 0
    else
      printf "  %b %s — HTTP %s\n" "$WARN" "$label" "${code:-timeout}"
      return 1
    fi
  fi
  printf "  %b %s — curl missing, skip\n" "$WARN" "$label"
  return 1
}

# ============================================================================
# Section 1: REQUIRED — without these, hooks don't work
# ============================================================================
print_header "1. 必装依赖"

required_failures=0
check_cmd "Python 3" python --version || {
  check_cmd "Python 3 (alt name)" python3 --version || ((required_failures++))
}
check_cmd "Bash" bash --version >/dev/null && printf "  %b Bash — $(bash --version | head -1)\n" "$OK" || ((required_failures++))
check_cmd "Git" git --version || ((required_failures++))

# ============================================================================
# Section 2: HOOK SELF-TEST — can we actually execute our own hooks?
# ============================================================================
print_header "2. Hook 自检"

SKILL_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# polyglot dispatcher
if [ -x "$SKILL_ROOT/hooks/run-hook.cmd" ] || [ -f "$SKILL_ROOT/hooks/run-hook.cmd" ]; then
  printf "  %b polyglot 入口 hooks/run-hook.cmd\n" "$OK"
else
  printf "  %b polyglot 入口 hooks/run-hook.cmd 不存在\n" "$ERR"
fi

# python session-start.py via polyglot
if out=$(bash "$SKILL_ROOT/hooks/run-hook.cmd" session-start.py 2>&1) && echo "$out" | grep -q "hookSpecificOutput\|additional_context"; then
  printf "  %b SessionStart hook (Python 路径)\n" "$OK"
else
  printf "  %b SessionStart hook — 输出异常或无 Python\n" "$WARN"
fi

# bash hooks
for h in check-memory-files inject-context remind-update; do
  if bash "$SKILL_ROOT/hooks/run-hook.cmd" "$h" >/dev/null 2>&1; then
    printf "  %b %s\n" "$OK" "$h"
  else
    printf "  %b %s — 执行失败\n" "$WARN" "$h"
  fi
done

# ============================================================================
# Section 3: RECOMMENDED — shared 工具 + 兄弟 skill + grok-search
# ============================================================================
print_header "3. 推荐依赖（缺失时降级，不阻塞）"

echo ""
echo "  -- shared/ 工程画像与工具管理 --"
check_path "shared/project_detect.py" "$HOME/.claude/skills/shared/project_detect.py"
check_path "shared/tool_config.py"    "$HOME/.claude/skills/shared/tool_config.py"

echo ""
echo "  -- grok-search 联网检索 --"
check_path "grok_search.py" "$HOME/.claude/skills/grok-search/scripts/grok_search.py"
check_path "grok-search config.json" "$HOME/.claude/skills/grok-search/config.json"

echo ""
echo "  -- 兄弟 skill (按需安装) --"
sibling_skills=(build-cmake build-keil build-iar build-platformio build-idf build-makefile
                flash-openocd flash-keil flash-platformio flash-idf flash-jlink
                debug-gdb-openocd debug-jlink debug-platformio
                serial-monitor modbus-debug can-debug visa-debug
                memory-analysis rtos-debug static-analysis
                peripheral-driver stm32-hal-development workflow
                simplify codex)
installed=0
missing=0
for s in "${sibling_skills[@]}"; do
  if [ -d "$HOME/.claude/skills/$s" ] || [ -d "$HOME/.claude/plugins/$s" ]; then
    ((installed++))
  else
    ((missing++))
  fi
done
printf "  汇总：%b 已装 %d 个 / %b 未装 %d 个 (共 %d，按需补)\n" \
  "$OK" "$installed" "$WARN" "$missing" "$((installed + missing))"

# ============================================================================
# Section 4: OPTIONAL — MCPs, CLIs for specific scenarios
# ============================================================================
print_header "4. 可选依赖（特定场景）"

check_cmd "gh CLI (GitHub 检索)" gh --version 2>/dev/null || true
check_cmd "curl (网络检测)" curl --version 2>/dev/null || true

if command -v claude >/dev/null 2>&1; then
  printf "  %b claude CLI — 可用于 claude mcp add ...\n" "$OK"
else
  printf "  %b claude CLI — 未在 PATH（若已 Claude Code 启动，无需此 CLI）\n" "$WARN"
fi

# ============================================================================
# Section 5: 网络可达性（grok-search 后端）
# ============================================================================
if command -v curl >/dev/null 2>&1; then
  print_header "5. 网络可达性（仅当 grok-search 已装时相关）"
  check_url "grok 网关 micuapi.ai"     "https://www.micuapi.ai/v1/models" || true
  check_url "GitHub API"               "https://api.github.com"            || true
fi

# ============================================================================
# Summary
# ============================================================================
print_header "总结"

if [ "$required_failures" -gt 0 ]; then
  echo ""
  printf "  %b 必装依赖有 %d 项缺失 — hook 会 fail open，但建议补齐。\n" "$ERR" "$required_failures"
  echo "     看 INSTALL.md 第 2 节获取安装方法。"
else
  echo ""
  printf "  %b 必装依赖齐全，核心 hook 可工作。\n" "$OK"
fi
echo "  缺失推荐/可选项不影响 RIPER-5 五阶段协议运行；EXECUTE 阶段会按需提示。"
echo ""

exit 0
